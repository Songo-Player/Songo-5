{
	"name": "Songo Classic",
	"version": "0.8",
	"author": "Riley",
	"description": "Original Songo#5 theme, based on minimalism and being user friendly.",
	"components": {
		"background_root": "background_root/background_root.tscn",
		"main_menu": "main_menu/main_menu.tscn",
		"header": "header/header.tscn",
		"main_song_view": "main_song_view/main_song_view.tscn",
		"footer": "footer/footer.tscn",
		"song_follow": "song_follow/song_follow.tscn",
		"collection_button": "collection_button/collection_button.tscn",
		"collection_header": "collection_header/collection_header.tscn"
	},
	"collection_options": {
		"vertical_layout": true,
		"list_top_fade": 0,
		"list_bottom_fade": 16,
		"list_container_margin_left": 40,
		"list_container_margin_right": 3,
	},
	"tags": [
		"minimal",
		"og",
		"customizable"
	],
	"settings": {
		"songo_clock_24_hour": {
			"values": [true, false],
			"default": true,
			"display_name": "24 Hour Clock",
			"dependents": ["header"]
		},
		"songo_background_color": {
			"values": [
				"48486d", 
				"84233b",
				"215a30", 
				"562b90",
				"7c2a00",
				"004988", 
				"d57200", 
				"5865F2",
				"cc1111", 
				"FB6F92",
				"777",
			],
			"labels": [
				"Grayish Blue",
				"Purpley",
				"Emerald Green",
				"Purpley Blue",
				"Burnt Orange",
				"Another Blue",
				"Pumpkin Spice",
				"Voice Chat Color",
				"Red-bernic",
				"Pink?",
				"Oops! No color!"
			],
			"default": "48486d",
			"display_name": "Background Color",
			"dependents": ["background_root"]
		},
		"songo_main_menu_size": {
			"values": [124, 172, 220],
			"labels": ["SM", "MD", "LG"],
			"default": 172,
			"display_name": "Main Menu Size",
			"dependents": ["main_menu"]
		},
		"songo_all_songs_menu_visibility": {
			"values": [true, false],
			"labels": ["Visible", "Hidden"],
			"button_text": ["Hide", "Show"],
			"default": true,
			"display_name": "All Songs Menu Item",
			"dependents": ["main_menu"]
		},
		"songo_albums_menu_visibility": {
			"values": [true, false],
			"labels": ["Visible", "Hidden"],
			"button_text": ["Hide", "Show"],
			"default": true,
			"display_name": "Albums Menu Item",
			"dependents": ["main_menu"]
		},
		"songo_artists_menu_visibility": {
			"values": [true, false],
			"labels": ["Visible", "Hidden"],
			"button_text": ["Hide", "Show"],
			"default": true,
			"display_name": "Artists Menu Item",
			"dependents": ["main_menu"]
		},
		"songo_playlists_menu_visibility": {
			"values": [true, false],
			"labels": ["Visible", "Hidden"],
			"button_text": ["Hide", "Show"],
			"default": true,
			"display_name": "Playlists Menu Item",
			"dependents": ["main_menu"]
		},
	}
}
